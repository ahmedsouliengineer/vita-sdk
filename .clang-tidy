# 1. Select the Check Suites
Checks: >
  -*,
  bugprone-*,
  cppcoreguidelines-*,
  modernize-*,
  performance-*,
  readability-*,
  google-readability-casting,
  misc-definitions-in-headers,
  misc-unused-parameters,
  misc-unused-using-decls
  # I am adding this to ensure we don't use old-school 'NULL' 
  # or 'errno' now that we have std::expected.
  modernize-use-nullptr,
  modernize-use-auto

# 2. Treat warnings as build-failing errors
WarningsAsErrors: '*'

# 3. Configure specific check behaviors
# I am allowing Clang-Tidy to suggest 'std::expected' patterns 
# where it sees old-fashioned error-code-returning functions.
CheckOptions:
  - key:             modernize-use-std-print
    value:           'true'
  - key:             cppcoreguidelines-special-member-functions.AllowMissingMoveFunctions
    value:           '1'
  - key:             modernize-use-trailing-return-type.IgnoreMacros
    value:           '1'
  - key:             readability-function-size.LineThreshold
    value:           '60'
  - key:             readability-identifier-naming.VariableCase
    value:           'lower_case'
  - key:             readability-identifier-naming.ClassCase
    value:           'CamelCase'